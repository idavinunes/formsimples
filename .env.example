# Host do servidor
# 127.0.0.1 = somente a propria maquina
# 0.0.0.0 = acessivel pela rede local
HOST=127.0.0.1

# Porta local do servidor
PORT=4173

# URL do webhook do n8n
WEBHOOK_URL=https://seu-n8n/webhook/onix-documentos

# Opcional: header secreto para autenticar no n8n
WEBHOOK_AUTH_HEADER_NAME=
WEBHOOK_AUTH_HEADER_VALUE=

# Timeout do proxy em milissegundos
PROXY_TIMEOUT_MS=45000
